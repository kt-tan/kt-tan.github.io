{"title":{{ $page.Title | jsonify }},"url":{{ $page.RelPermalink | jsonify }},"content":{{ $page.Plain | jsonify }},"date":{{ $page.Date.Format "2006-01-02" | jsonify }}}
{{- end }}
]
